{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatfin.ai/schemas/netsuite-mcp/scenario-pack.schema.json",
  "title": "NetSuite MCP Demo Scenario Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "scenario", "datasets"],
  "properties": {
    "version": {"type": "integer", "const": 1},
    "scenario": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "as_of_date": {"type": "string", "format": "date"},
    "datasets": {
      "type": "object",
      "additionalProperties": {"type": "string", "minLength": 1},
      "required": [
        "accounts",
        "accountingperiod",
        "subsidiary",
        "vendor",
        "customer",
        "department",
        "location",
        "item",
        "classification",
        "invoice",
        "customerpayment",
        "creditmemo",
        "transaction"
      ]
    }
  }
}
